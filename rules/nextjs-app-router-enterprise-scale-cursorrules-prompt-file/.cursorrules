# Next.js App Router Enterprise Scale Development Rules

You are an expert senior software engineer specializing in building medium-to-high scale applications using Next.js App Router. You have deep expertise in enterprise architecture, performance optimization, scalability, and modern web development best practices.

## Project Architecture & Structure

### App Router Directory Structure
```
app/
├── (auth)/                    # Route groups for authentication
│   ├── login/
│   ├── register/
│   └── layout.tsx
├── (dashboard)/               # Route groups for dashboard
│   ├── overview/
│   ├── analytics/
│   └── layout.tsx
├── api/                       # API routes
│   ├── auth/
│   ├── users/
│   └── middleware.ts
├── components/                # Shared components
│   ├── ui/                    # Base UI components
│   ├── forms/                 # Form components
│   ├── layout/                # Layout components
│   └── providers/             # Context providers
├── hooks/                     # Custom hooks
├── lib/                       # Utility functions and configurations
│   ├── auth.ts
│   ├── db.ts
│   ├── utils.ts
│   └── validations.ts
├── middleware.ts              # Next.js middleware
├── globals.css                # Global styles
├── layout.tsx                 # Root layout
└── page.tsx                   # Home page
```

### Key Architectural Principles
- **Server-First Approach**: Use Server Components by default, Client Components only when necessary
- **Route Groups**: Organize related routes using parentheses notation for better code organization
- **Parallel Routes**: Implement parallel routes for complex layouts (e.g., dashboard with sidebar + main content)
- **Intercepting Routes**: Use intercepting routes for modal dialogs and overlays
- **Streaming**: Implement streaming for better perceived performance

## Component Architecture

### Server Components (Default)
```typescript
// Use Server Components for:
// - Data fetching
// - Database queries
// - File system access
// - API calls
// - Authentication checks

export default async function UserProfile({ userId }: { userId: string }) {
  const user = await getUser(userId);
  const posts = await getUserPosts(userId);
  
  return (
    <div>
      <h1>{user.name}</h1>
      <PostsList posts={posts} />
    </div>
  );
}
```

### Client Components (When Needed)
```typescript
'use client';

// Use Client Components for:
// - Interactivity (onClick, onChange)
// - Browser APIs (localStorage, window)
// - Event listeners
// - State management
// - Third-party libraries requiring client-side execution

import { useState } from 'react';

export default function InteractiveForm() {
  const [formData, setFormData] = useState({});
  
  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    // Handle form submission
  };
  
  return (
    <form onSubmit={handleSubmit}>
      {/* Form fields */}
    </form>
  );
}
```

### Component Composition Patterns
```typescript
// Container/Presentational Pattern
export default function UserListContainer() {
  const users = await getUsers();
  return <UserList users={users} />;
}

// Higher-Order Components for cross-cutting concerns
export function withAuth<P extends object>(
  Component: React.ComponentType<P>
) {
  return async function AuthenticatedComponent(props: P) {
    const session = await getSession();
    if (!session) redirect('/login');
    return <Component {...props} />;
  };
}
```

## Data Fetching & State Management

### Server-Side Data Fetching
```typescript
// Use React's built-in data fetching
export default async function DashboardPage() {
  // Parallel data fetching for better performance
  const [users, posts, analytics] = await Promise.all([
    getUsers(),
    getPosts(),
    getAnalytics()
  ]);
  
  return (
    <Dashboard 
      users={users} 
      posts={posts} 
      analytics={analytics} 
    />
  );
}

// Implement proper error handling
export default async function UserPage({ params }: { params: { id: string } }) {
  try {
    const user = await getUser(params.id);
    if (!user) notFound();
    
    return <UserProfile user={user} />;
  } catch (error) {
    // Log error for monitoring
    console.error('Failed to fetch user:', error);
    throw new Error('Failed to load user profile');
  }
}
```

### Client-Side State Management
```typescript
// Use React's built-in state management
'use client';

import { useOptimistic, useTransition } from 'react';

export function OptimisticUpdate() {
  const [isPending, startTransition] = useTransition();
  const [optimisticData, addOptimisticData] = useOptimistic();
  
  const handleUpdate = async (newData: any) => {
    addOptimisticData(newData); // Immediate UI update
    
    startTransition(async () => {
      await updateData(newData); // Actual API call
    });
  };
  
  return (
    <div>
      {isPending && <LoadingSpinner />}
      {/* Render optimistic data */}
    </div>
  );
}
```

### Global State Management
```typescript
// For complex state, use Zustand or Jotai
// Avoid Redux for most cases - React's built-in state is sufficient

import { create } from 'zustand';

interface AppState {
  user: User | null;
  theme: 'light' | 'dark';
  setUser: (user: User | null) => void;
  setTheme: (theme: 'light' | 'dark') => void;
}

export const useAppStore = create<AppState>((set) => ({
  user: null,
  theme: 'light',
  setUser: (user) => set({ user }),
  setTheme: (theme) => set({ theme }),
}));
```

