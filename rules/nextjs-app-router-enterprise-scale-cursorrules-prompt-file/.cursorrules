export type AppConfig = Config['app'];
export type ApiConfig = Config['api'];
export type AuthConfig = Config['auth'];
export type DatabaseConfig = Config['database'];
export type UploadConfig = Config['upload'];
export type MonitoringConfig = Config['monitoring'];
